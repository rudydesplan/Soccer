# Copy to deploy.cloudrun.env and adjust for your GCP project.
# deploy.cloudrun.env is gitignored (may contain project-specific names).
#
#   cp deploy.cloudrun.env.example deploy.cloudrun.env

# Required
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=europe-west1

# Artifact Registry (repo must exist in GCP_REGION; create if needed:
#   gcloud artifacts repositories create cloud-run-source-deploy \
#     --repository-format=docker --location=$GCP_REGION)
ARTIFACT_REGISTRY_REPO=cloud-run-source-deploy
IMAGE_NAME=soccer-benchmark
IMAGE_TAG=latest

# Cloud Run service name (URL slug: https://SERVICE_NAME-....run.app)
SERVICE_NAME=soccer-salary-benchmark

# Set to false if you lack run.services.setIamPolicy (public binding will be skipped)
MAKE_PUBLIC=true
